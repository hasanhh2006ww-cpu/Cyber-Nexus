# Neon PostgreSQL connection string (required)
# Format: postgresql://username:password@host/database?sslmode=require
DATABASE_URL="postgresql://username:password@your-neon-host.neon.tech/dbname?sslmode=require"

# NextAuth.js secret (required)
# NextAuth v5 checks AUTH_SECRET first, then NEXTAUTH_SECRET.
# Set both to the SAME value if you use both names.
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-change-in-production"
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# NextAuth.js URL (required)
# In production: https://your-app.vercel.app
# In development: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob (required for file uploads)
# Create a Blob store at https://vercel.com/dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# YouTube Data API v3 (optional, for YouTube playlist import feature)
# Get a key at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY="your-youtube-api-key"
